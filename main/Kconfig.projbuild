menu "Dosing Pump Controller Configuration"

config CONTROLLER_ENABLE_BLE_PROVISIONING
    bool "Enable BLE provisioning"
    default y
    help
        Enable the BLE-assisted onboarding flow. When disabled, the firmware
        uses the legacy AP-only onboarding behavior and does not depend on the
        BLE provisioning component.

config CONTROLLER_WIFI_SSID
    string "AP WiFi SSID"
    default "DOSING"
    help
        SSID (network name) for the example to connect to.

config CONTROLLER_WIFI_PASS
    string "AP WiFi Password"
    default "12345678"
    help
        WiFi password (WPA2 or WPA3) for the example to use.
        Can be left blank if the network has no security set.

config CONTROLLER_WIFI_CHANNEL
    int "WiFi Channel"
    range 1 13
    default 1
    help
        WiFi SoftAp channel (network channel).

config CONTROLLER_WIFI_AP_GRACE_TIMEOUT_SEC
    int "AP grace timeout (seconds)"
    depends on CONTROLLER_ENABLE_BLE_PROVISIONING
    range 10 3600
    default 120
    help
        How long the fallback AP should remain available after a successful
        provisioning/recovery station connection before switching to STA-only,
        unless keep_ap_active is enabled.

config CONTROLLER_WIFI_AP_FALLBACK_TIMEOUT_SEC
    int "AP fallback timeout (seconds)"
    range 30 3600
    default 300
    help
        How long the recovery/fallback AP should remain active without clients
        before retrying the station connection sequence.

endmenu
