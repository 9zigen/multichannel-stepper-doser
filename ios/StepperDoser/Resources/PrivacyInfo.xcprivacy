<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Does this app use data for tracking? No. -->
	<key>NSPrivacyTracking</key>
	<false/>

	<!-- Domains used for tracking (none). -->
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- Data types collected and sent off-device (none — all comms stay on LAN). -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>

	<!-- Required-reason APIs used by this app. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- UserDefaults — used by ManagedDeviceStore to persist the device
			     list and selected-device preference on the local device only. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- CA92.1: Access info from the same app (device list + selection) -->
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
